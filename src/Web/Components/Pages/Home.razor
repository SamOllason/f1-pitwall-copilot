@page "/"
@using Application.Features.AskPitWall
@using Application.Features.DriverPerformance
@inject IAskPitWallService AskPitWallService
@inject IDriverPerformanceQueryService DriverPerformanceQueryService
@inject IJSRuntime JS

<PageTitle>🏎️ Formula 1 Pitwall Copilot</PageTitle>

<div class="page-header">
    <h1>🏎️ Formula 1 Pitwall Copilot</h1>
    <p>Pace, teammate delta, and race trend from seeded telemetry - ask PitWall to go deeper.</p>
</div>


<section class="ask-section">

    <details class="prompts-details mb-3">
        <summary>Suggested questions</summary>
        <div class="prompt-list">
            @foreach (var prompt in SuggestedPrompts)
            {
                <div class="prompt-item">
                    <span class="prompt-text">@prompt</span>
                    <button class="btn btn-outline-primary" type="button"
                            @onclick="() => UsePrompt(prompt)" disabled="@isAsking">Use</button>
                    <button class="btn btn-outline-secondary" type="button"
                            @onclick="() => CopyPromptAsync(prompt)" disabled="@isAsking">
                        @(string.Equals(lastCopiedPrompt, prompt, StringComparison.Ordinal) ? "Copied" : "Copy")
                    </button>
                </div>
            }
        </div>
    </details>

    <div class="ask-input-row">
        <input class="form-control"
               placeholder="e.g. Why does Lando struggle with rear instability at Silverstone?"
               @bind="pitWallQuestion"
               @bind:event="oninput"
               disabled="@isAsking" />
        <button class="btn btn-primary" @onclick="AskPitWallAsync" disabled="@isAsking">
            @(isAsking ? "Thinking..." : "Ask")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(askError))
    {
        <div class="alert alert-danger mt-2 mb-0 py-2" role="alert">@askError</div>
    }

    @if (askResult is not null)
    {
        <div class="result-grid mt-3">

            
            <div class="answer-card">
                <div class="answer-text">
                    @foreach (var paragraph in BuildAnswerParagraphs(askResult.Answer))
                    {
                        <p class="answer-paragraph">@paragraph</p>
                    }
                </div>

                <div class="confidence-row">
                    <span class="confidence-label">Confidence score</span>
                    <span class="confidence-badge @ConfidenceBadgeClass(askResult.Confidence.Level)">
                        @askResult.Confidence.Level
                    </span>
                    <span class="confidence-rationale">@askResult.Confidence.Rationale</span>
                </div>

                @if (askResult.UsedFallback)
                {
                    <div class="fallback-notice">Fallback mode - AI path unavailable, showing deterministic stats.</div>
                }

                @if (askResult.SourceMetrics.Count > 0)
                {
                    <details class="source-section">
                        <summary>Source evidence (@askResult.SourceMetrics.Count)</summary>
                        <ul class="source-list">
                            @foreach (var metric in askResult.SourceMetrics)
                            {
                                <li>@metric</li>
                            }
                        </ul>
                    </details>
                }

                <div class="meta-row">
                    <span>Request:</span> <code class="me-2">@askResult.RequestId[..8]</code>
                    <span class="ms-2">Latency:</span> <span>@askResult.LatencyMs ms</span>
                    @if (askResult.TotalTokens.HasValue)
                    {
                        <span class="ms-2">Tokens:</span> <span>@askResult.TotalTokens tok</span>
                    }
                </div>
            </div>

            
            <div class="audit-panel">
                <div class="audit-panel-title">Audit Trail</div>
                <div class="audit-scroll">
                    @foreach (var entry in askResult.AuditTrail)
                    {
                        <div class="audit-entry">
                            <span class="audit-stage-pill @StagePillClass(entry.Stage)">@entry.Stage</span>
                            <div class="audit-body">
                                <div class="audit-decision">@entry.Decision</div>
                                @if (!string.IsNullOrWhiteSpace(entry.Detail))
                                {
                                    <div class="audit-detail">@entry.Detail</div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (askResult.ToolCalls.Count > 0)
                {
                    <div class="audit-subsection">
                        <div class="audit-subsection-title">Tools called</div>
                        @foreach (var call in askResult.ToolCalls)
                        {
                            <span class="audit-tool-chip">@call</span>
                        }
                    </div>
                }

                <div class="audit-subsection">
                    <div class="audit-subsection-title">Usage</div>
                    <div class="audit-usage-row">
                        <span>Prompt</span><span>@(askResult.PromptTokens?.ToString() ?? "n/a") tok</span>
                        <span>Completion</span><span>@(askResult.CompletionTokens?.ToString() ?? "n/a") tok</span>
                        <span>Total</span><span>@(askResult.TotalTokens?.ToString() ?? "n/a") tok</span>
                        <span>Latency</span><span>@askResult.LatencyMs ms</span>
                    </div>
                </div>
            </div>

        </div>
    }
</section>


<div class="filters">
    <div class="filter-item">
        <label class="form-label" for="driverFilter">Driver</label>
        <select id="driverFilter" class="form-select" value="@SelectedDriverValue"
                @onchange="OnDriverChanged" disabled="@isLoading">
            <option value="">All drivers</option>
            @foreach (var driver in dashboard?.Drivers ?? [])
            {
                <option value="@driver.DriverId">@driver.DriverName (@driver.Team)</option>
            }
        </select>
    </div>
    <div class="filter-item">
        <label class="form-label" for="raceFilter">Race</label>
        <select id="raceFilter" class="form-select" value="@SelectedRaceValue"
                @onchange="OnRaceChanged" disabled="@isLoading">
            <option value="">All races</option>
            @foreach (var race in dashboard?.Races ?? [])
            {
                <option value="@race.RaceId">@race.RaceName (@race.Date.ToString("yyyy-MM-dd"))</option>
            }
        </select>
    </div>
</div>

@if (isLoading)
{
    <p class="text-muted"><em>Loading...</em></p>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-danger" role="alert">@loadError</div>
}
else if (dashboard is null || dashboard.Rows.Count == 0)
{
    <div class="alert alert-warning" role="alert">No results for this filter combination.</div>
}
else
{
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="section-label">Overview</div>
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Driver</th>
                        <th>Team</th>
                        <th>Avg Lap (s)</th>
                        <th>Delta to Teammate (s)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in dashboard.Rows)
                    {
                        <tr>
                            <td>@row.DriverName</td>
                            <td>@row.Team</td>
                            <td>@row.AverageLapTimeSeconds</td>
                            <td>@row.DeltaToTeammateSeconds</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="section-label">Trend Over Races</div>
            @if (dashboard.Trend.Count == 0)
            {
                <p class="mb-0 text-muted" style="font-size:0.85rem">Select a driver to view trend data.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Race</th>
                            <th>Date</th>
                            <th>Avg Lap (s)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var point in dashboard.Trend)
                        {
                            <tr>
                                <td>@point.RaceName</td>
                                <td>@point.RaceDate.ToString("yyyy-MM-dd")</td>
                                <td>@point.AverageLapTimeSeconds</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private DriverPerformanceDashboardDto? dashboard;
    private bool isLoading = true;
    private string? loadError;
    private int? selectedDriverId;
    private int? selectedRaceId;
    private string pitWallQuestion = string.Empty;
    private bool isAsking;
    private string? askError;
    private AskPitWallResponseDto? askResult;
    private string? lastCopiedPrompt;

    private static readonly string[] SuggestedPrompts =
    [
        // Silverstone - driver debrief
        "Why does Lando struggle with rear instability at Silverstone, and how does it affect his pace?",
        "After a rear snap at Silverstone 2025, what short-run performance pattern showed up for Lando?",

        // Silverstone - race briefing
        "What tire strategy is recommended for the British Grand Prix 2025?",
        "What are the main setup priorities for Silverstone 2025?",

        // Suzuka - race briefing
        "What is the setup direction for the Esses at Suzuka 2025?",
        "How does soft tire degradation compare to medium at Suzuka 2025?",

        // Cross-circuit
        "Comparing Silverstone and Suzuka 2025, where are we most vulnerable and why?",
    ];

    private string SelectedDriverValue => selectedDriverId?.ToString() ?? string.Empty;
    private string SelectedRaceValue => selectedRaceId?.ToString() ?? string.Empty;

    protected override async Task OnInitializedAsync() => await LoadDashboardAsync();

    private async Task OnDriverChanged(ChangeEventArgs args)
    {
        selectedDriverId = TryParseOptionalInt(args.Value?.ToString());
        await LoadDashboardAsync();
    }

    private async Task OnRaceChanged(ChangeEventArgs args)
    {
        selectedRaceId = TryParseOptionalInt(args.Value?.ToString());
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        loadError = null;
        try
        {
            dashboard = await DriverPerformanceQueryService.GetDashboardAsync(selectedDriverId, selectedRaceId);
        }
        catch (Exception)
        {
            loadError = "Could not load driver performance data. Please retry.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AskPitWallAsync()
    {
        if (string.IsNullOrWhiteSpace(pitWallQuestion))
        {
            askError = "Type a question before asking PitWall.";
            return;
        }

        isAsking = true;
        askError = null;
        try
        {
            askResult = await AskPitWallService.AskAsync(pitWallQuestion.Trim());
        }
        catch (Exception)
        {
            askError = "Could not process this question. Please retry.";
        }
        finally
        {
            isAsking = false;
        }
    }

    private void UsePrompt(string prompt) => pitWallQuestion = prompt;

    private async Task CopyPromptAsync(string prompt)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", prompt);
        lastCopiedPrompt = prompt;
    }

    private static int? TryParseOptionalInt(string? input) =>
        int.TryParse(input, out var value) ? value : null;

    private static string ConfidenceBadgeClass(ConfidenceLevel level) => level switch
    {
        ConfidenceLevel.High    => "bg-success text-white",
        ConfidenceLevel.Medium  => "bg-warning text-dark",
        ConfidenceLevel.Low     => "bg-danger text-white",
        ConfidenceLevel.VeryLow => "bg-secondary text-white",
        _                       => "bg-secondary text-white"
    };

    private static string StagePillClass(string stage)
    {
        var key = stage.ToLowerInvariant().Replace(" ", "").Replace("(", "").Replace(")", "");
        return key switch
        {
            "input"                  => "stage-input",
            "policy"                 => "stage-policy",
            "rag"                    => "stage-rag",
            "ragchunkupfront"        => "stage-ragchunk",
            "ragchunktool"           => "stage-ragchunk",
            "decision"               => "stage-decision",
            "toolresult"             => "stage-toolresult",
            "result"                 => "stage-result",
            "confidence"             => "stage-confidence",
            "fallback"               => "stage-fallback",
            _                        => "stage-default"
        };
    }

    private static IReadOnlyList<string> BuildAnswerParagraphs(string answer)
    {
        if (string.IsNullOrWhiteSpace(answer))
        {
            return ["No answer generated."];
        }

        var compact = string.Join(" ", answer.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
        var sentences = SplitSentences(compact);
        if (sentences.Count <= 2)
        {
            return [compact];
        }

        var paragraphs = new List<string>();
        for (var i = 0; i < sentences.Count; i += 2)
        {
            var chunk = sentences.Skip(i).Take(2);
            paragraphs.Add(string.Join(" ", chunk));
        }

        return paragraphs;
    }

    private static List<string> SplitSentences(string text)
    {
        var sentences = new List<string>();
        var start = 0;

        for (var i = 0; i < text.Length; i++)
        {
            if (text[i] is '.' or '!' or '?')
            {
                var length = i - start + 1;
                if (length > 0)
                {
                    var sentence = text.Substring(start, length).Trim();
                    if (!string.IsNullOrWhiteSpace(sentence))
                    {
                        sentences.Add(sentence);
                    }
                }

                start = i + 1;
            }
        }

        if (start < text.Length)
        {
            var trailing = text[start..].Trim();
            if (!string.IsNullOrWhiteSpace(trailing))
            {
                sentences.Add(trailing);
            }
        }

        return sentences.Count > 0 ? sentences : [text];
    }
}

