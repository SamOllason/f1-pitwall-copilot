@page "/"
@using Application.Features.AskPitWall
@using Application.Features.DriverPerformance
@inject IAskPitWallService AskPitWallService
@inject IDriverPerformanceQueryService DriverPerformanceQueryService
@inject IJSRuntime JS

<PageTitle>PitWall Dashboard</PageTitle>

<h1>Driver Performance Dashboard</h1>

<p class="text-muted">Explore average pace, teammate delta, and race trend from seeded telemetry.</p>

    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Ask PitWall</h2>
            <p class="text-muted mb-3">Ask naturally, and PitWall will pull relevant context and tool outputs behind the scenes.</p>

            <details class="mb-3">
                <summary class="fw-semibold">Show suggested RAG prompts</summary>
                <p class="text-muted mt-2 mb-2">Try realistic questions a user would actually ask while still showcasing retrieval in the audit trail.</p>
                <div class="d-grid gap-2">
                    @foreach (var prompt in SuggestedPrompts)
                    {
                        <div class="border rounded p-2">
                            <div class="small mb-2">@prompt</div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary"
                                        type="button"
                                        @onclick="() => UsePrompt(prompt)"
                                        disabled="@isAsking">
                                    Use
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        type="button"
                                        @onclick="() => CopyPromptAsync(prompt)"
                                        disabled="@isAsking">
                                    Copy
                                </button>
                                @if (string.Equals(lastCopiedPrompt, prompt, StringComparison.Ordinal))
                                {
                                    <span class="small text-success align-self-center">Copied</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </details>

            <div class="input-group mb-3">
                <input class="form-control"
                       placeholder="e.g. At Silverstone 2025, what were the biggest risks and setup priorities?"
                       @bind="pitWallQuestion"
                       @bind:event="oninput"
                       disabled="@isAsking" />
                <button class="btn btn-primary"
                        @onclick="AskPitWallAsync"
                        disabled="@isAsking">
                    @(isAsking ? "Asking..." : "Ask")
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(askError))
            {
                <div class="alert alert-danger" role="alert">@askError</div>
            }

            @if (askResult is not null)
            {
                <div class="row g-3">
                    <div class="col-lg-8">
                        <div class="border rounded p-3 bg-light-subtle h-100">
                            <p class="mb-2"><strong>Answer:</strong> @askResult.Answer</p>
                            <p class="mb-2"><strong>Why this result:</strong> @askResult.WhySummary</p>
                            <p class="mb-2 small text-muted">
                                Request: <code>@askResult.RequestId</code> |
                                Latency: @askResult.LatencyMs ms |
                                Tokens: @(askResult.TotalTokens?.ToString() ?? "n/a")
                            </p>
                            @if (askResult.UsedFallback)
                            {
                                <p class="mb-2 text-warning-emphasis"><strong>Fallback:</strong> Tool/AI path failed, showing deterministic stats.</p>
                            }

                            @if (askResult.SourceMetrics.Count > 0)
                            {
                                <p class="mb-1"><strong>Source metrics</strong></p>
                                <p class="mb-2"><em>Look for retrieved RAG entries (race/driver/source path) and tool-derived metrics; this shows exactly what evidence grounded the answer.</em></p>
                                <ul class="mb-0">
                                    @foreach (var metric in askResult.SourceMetrics)
                                    {
                                        <li>@metric</li>
                                    }
                                </ul>
                            }
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 mb-2">Audit Trail</h3>
                            <p class="mb-2"><em>Look for the sequence: Input -> Policy -> RAG retrieval -> Tool decision -> Tool result -> Final result, which makes the reasoning path transparent.</em></p>
                            @if (askResult.AuditTrail.Count == 0)
                            {
                                <p class="mb-0 text-muted">No audit events captured.</p>
                            }
                            else
                            {
                                <ol class="mb-0 ps-3">
                                    @foreach (var entry in askResult.AuditTrail)
                                    {
                                        <li class="mb-2">
                                            <div><strong>@entry.Stage:</strong> @entry.Decision</div>
                                            <div class="text-muted small">@entry.Detail</div>
                                        </li>
                                    }
                                </ol>
                            }
                            @if (askResult.ToolCalls.Count > 0)
                            {
                                <p class="mt-3 mb-1"><strong>Tools used</strong></p>
                                <ul class="mb-0">
                                    @foreach (var call in askResult.ToolCalls)
                                    {
                                        <li><code>@call</code></li>
                                    }
                                </ul>
                            }
                            <p class="mt-3 mb-1"><strong>Usage</strong></p>
                            <ul class="mb-0">
                                <li>Prompt tokens: @(askResult.PromptTokens?.ToString() ?? "n/a")</li>
                                <li>Completion tokens: @(askResult.CompletionTokens?.ToString() ?? "n/a")</li>
                                <li>Total tokens: @(askResult.TotalTokens?.ToString() ?? "n/a")</li>
                                <li>Latency: @askResult.LatencyMs ms</li>
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

<div class="filters mb-3">
    <div class="filter-item">
        <label class="form-label" for="driverFilter">Driver</label>
        <select id="driverFilter" class="form-select" value="@SelectedDriverValue" @onchange="OnDriverChanged" disabled="@isLoading">
            <option value="">All drivers</option>
            @foreach (var driver in dashboard?.Drivers ?? [])
            {
                <option value="@driver.DriverId">@driver.DriverName (@driver.Team)</option>
            }
        </select>
    </div>
    <div class="filter-item">
        <label class="form-label" for="raceFilter">Race</label>
        <select id="raceFilter" class="form-select" value="@SelectedRaceValue" @onchange="OnRaceChanged" disabled="@isLoading">
            <option value="">All races</option>
            @foreach (var race in dashboard?.Races ?? [])
            {
                <option value="@race.RaceId">@race.RaceName (@race.Date.ToString("yyyy-MM-dd"))</option>
            }
        </select>
    </div>
</div>

@if (isLoading)
{
    <p><em>Loading driver performance...</em></p>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-danger" role="alert">
        @loadError
    </div>
}
else if (dashboard is null || dashboard.Rows.Count == 0)
{
    <div class="alert alert-warning" role="alert">
        No results found for this filter combination.
    </div>
}
else
{
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Overview</h2>
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Driver</th>
                        <th>Team</th>
                        <th>Average Lap (s)</th>
                        <th>Delta to Teammate (s)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in dashboard.Rows)
                    {
                        <tr>
                            <td>@row.DriverName</td>
                            <td>@row.Team</td>
                            <td>@row.AverageLapTimeSeconds</td>
                            <td>@row.DeltaToTeammateSeconds</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Trend Over Races</h2>
            @if (dashboard.Trend.Count == 0)
            {
                <p class="mb-0 text-muted">Select a driver to view trend data over races.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Race</th>
                            <th>Date</th>
                            <th>Average Lap (s)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var point in dashboard.Trend)
                        {
                            <tr>
                                <td>@point.RaceName</td>
                                <td>@point.RaceDate.ToString("yyyy-MM-dd")</td>
                                <td>@point.AverageLapTimeSeconds</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private DriverPerformanceDashboardDto? dashboard;
    private bool isLoading = true;
    private string? loadError;
    private int? selectedDriverId;
    private int? selectedRaceId;
    private string pitWallQuestion = string.Empty;
    private bool isAsking;
    private string? askError;
    private AskPitWallResponseDto? askResult;
    private string? lastCopiedPrompt;
    private static readonly string[] SuggestedPrompts =
    [
        // Silverstone — driver debrief
        "Why does Lando struggle with rear instability at Silverstone, and how does it affect his pace?",
        "After a rear snap at Silverstone 2025, what short-run performance pattern showed up for Lando?",

        // Silverstone — race briefing
        "What tire strategy is recommended for the British Grand Prix 2025?",
        "What are the main setup priorities for Silverstone 2025?",

        // Suzuka — race briefing
        "What is the setup direction for the Esses at Suzuka 2025?",
        "How does soft tire degradation compare to medium at Suzuka 2025?",

        // Cross-circuit
        "Comparing Silverstone and Suzuka 2025, where are we most vulnerable and why?",
    ];

    private string SelectedDriverValue => selectedDriverId?.ToString() ?? string.Empty;
    private string SelectedRaceValue => selectedRaceId?.ToString() ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task OnDriverChanged(ChangeEventArgs args)
    {
        selectedDriverId = TryParseOptionalInt(args.Value?.ToString());
        await LoadDashboardAsync();
    }

    private async Task OnRaceChanged(ChangeEventArgs args)
    {
        selectedRaceId = TryParseOptionalInt(args.Value?.ToString());
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            dashboard = await DriverPerformanceQueryService.GetDashboardAsync(selectedDriverId, selectedRaceId);
        }
        catch (Exception)
        {
            loadError = "Could not load driver performance data. Please retry.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AskPitWallAsync()
    {
        if (string.IsNullOrWhiteSpace(pitWallQuestion))
        {
            askError = "Type a question before asking PitWall.";
            return;
        }

        isAsking = true;
        askError = null;
        try
        {
            askResult = await AskPitWallService.AskAsync(pitWallQuestion.Trim());
        }
        catch (Exception)
        {
            askError = "Could not process this question. Please retry.";
        }
        finally
        {
            isAsking = false;
        }
    }

    private void UsePrompt(string prompt)
    {
        pitWallQuestion = prompt;
    }

    private async Task CopyPromptAsync(string prompt)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", prompt);
        lastCopiedPrompt = prompt;
    }

    private static int? TryParseOptionalInt(string? input)
    {
        return int.TryParse(input, out var value) ? value : null;
    }
}
